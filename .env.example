# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
COMPANIES_HOUSE_API_KEY=
COMPANIES_HOUSE_BASE_URL=https://api.company-information.service.gov.uk
ISSUER_PRIV_KEY=
ISSUER_PUB_KEY=

# --- Optional: Firecrawl for JS-rendered pages (LinkedIn, SPAs) ---
# Without this, web-lookup falls back to native fetch.
FIRECRAWL_API_KEY=

# --- Reputability scoring (defaults shown) ---
REPUTABILITY_THRESHOLD=4
REPUTABILITY_MEDIUM_THRESHOLD=2
REPUTABILITY_FOLLOWERS_HOST=5000
REPUTABILITY_FOLLOWERS_PRIMARY=10000
REPUTABILITY_ACCOUNT_AGE_MONTHS=12
REPUTABILITY_CROSS_PLATFORM_HANDLES=2
REPUTABILITY_THIRD_PARTY_COVERAGE=1
REPUTABILITY_MATCHED_DATA_POINTS=2

# --- Funding brackets (employer flow) ---
FUNDING_BRACKET_THRESHOLD=500k_2m
FUNDING_BRACKET_FALLBACK=500k_2m
FUNDING_BRACKET_UNKNOWN=lt_500k
# Override numeric cutoffs as JSON. Bracket = lowest band whose max > raised.
# FUNDING_BRACKET_CUTOFFS=[{"bracket":"lt_500k","max":500000},{"bracket":"500k_2m","max":2000000},{"bracket":"2m_10m","max":10000000},{"bracket":"gt_10m","max":1e308}]

# --- Companies House status → confidence tier (override as JSON map) ---
# COMPANY_STATUS_CONFIDENCE={"active":"very_high","dormant":"medium","liquidation":"low","dissolved":"low"}

# --- Web-lookup tuning ---
WEB_LOOKUP_TIMEOUT_MS=15000
WEB_LOOKUP_FIRECRAWL_TIMEOUT_MS=20000
WEB_LOOKUP_MAX_CONTENT_CHARS=10000
WEB_LOOKUP_NATIVE_MAX_CONTENT_CHARS=8000
WEB_LOOKUP_MAX_PRESS_SIGNALS=5
WEB_LOOKUP_MIN_CONTENT_CHARS=200
# CSV - override authority lists if you want to add/remove trusted domains
# WEB_LOOKUP_HIGH_AUTHORITY_DOMAINS=techcrunch.com,bloomberg.com,reuters.com,ft.com,wsj.com,forbes.com
# WEB_LOOKUP_MEDIUM_AUTHORITY_DOMAINS=linkedin.com,crunchbase.com,pitchbook.com

# --- Model routing (override to swap providers / versions) ---
MODEL_VISION=claude-opus-4-7
MODEL_EXTRACT=claude-haiku-4-5-20251001
MODEL_VERIFY=claude-sonnet-4-6
MODEL_SYNTHESIS=claude-sonnet-4-6

# --- Trace store (test override) ---
# TRACES_DB_PATH=./data/traces.db
